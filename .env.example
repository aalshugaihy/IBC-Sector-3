# Copy this file to `.env` and fill in strong values.
# Or just run `./deploy.sh` — it will generate `.env` for you automatically.

# Database password — keep this secret
DB_PASSWORD=change_me_to_random_string

# JWT signing secret — must be long and random (32+ bytes recommended)
JWT_SECRET=change_me_to_long_random_string_at_least_32_chars

# External port for the web UI.
# Default 80 (standard HTTP). If 80 is blocked by your provider/firewall,
# change to 8080 and visit http://YOUR_IP:8080/
WEB_PORT=80
