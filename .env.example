# ────────────────────────────────────────────────────────────────────
# IBC — قطاع الاستثمار وخدمات الأعمال — Environment Configuration
# Copy this file to `.env` (root) and `./server/.env` for local dev.
# `./deploy.sh` will auto-generate a secure root `.env` on first run.
# ────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ──────────────────────────────────────────
# Local Docker compose uses these defaults (created automatically).
DB_PASSWORD=change_me_to_random_string

# Full connection string. Required for production / Render / Supabase.
# Format: postgresql://USER:PASS@HOST:PORT/DBNAME
# DATABASE_URL=postgresql://ibc:change_me@localhost:5432/ibc_tasks

# Force SSL on/off. Auto-enabled when DATABASE_URL is set.
# PGSSL=true

# ─── Authentication (JWT) ───────────────────────────────────────────
# Must be a long random string (32+ bytes). Used to sign session tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_long_random_string_at_least_32_chars

# ─── AI / Chat (Optional) ───────────────────────────────────────────
# Required only for the AI chatbot and AI report generation features.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Server Configuration ───────────────────────────────────────────
# Port the Express API listens on. Render sets this automatically.
PORT=3001

# Comma-separated list of allowed CORS origins. Use the public URL of
# your deployed frontend. Leave blank for local dev defaults.
# CORS_ORIGIN=https://your-app.onrender.com

# Set to "true" to have Express also serve the built React frontend
# from /dist (single-service mode — used on Render).
SERVE_STATIC=false

# ─── Frontend / Docker ──────────────────────────────────────────────
# External HTTP port for the Docker compose deployment.
# Use 8080 if your provider blocks port 80.
WEB_PORT=80

# Dev only — frontend uses this to proxy /api in `npm run dev`.
VITE_API_URL=http://localhost:3001
