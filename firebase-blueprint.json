{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user or team member",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A task from the 2026 schedule",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "month": { "type": "string" },
        "status": { "type": "string", "enum": ["not-started", "ongoing", "completed", "overdue", "postponed", "cancelled"] },
        "assignedTo": { "type": "string", "description": "User UID" },
        "teamMembers": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "role": { "type": "string" }
            },
            "required": ["userId", "role"]
          }, 
          "description": "List of User UIDs with roles" 
        },
        "classification": { "type": "string" },
        "plannedDate": { "type": "string", "format": "date" },
        "actualDate": { "type": "string", "format": "date" },
        "completionPercentage": { "type": "number" },
        "notes": { "type": "string" },
        "obstacles": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "department", "month", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "taskId": { "type": "string" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Request": {
      "title": "Request",
      "description": "A request to track volume",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "Executive report generated by Gemini",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "period": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "generatedBy": { "type": "string" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "CustomRole": {
      "title": "Custom Role",
      "description": "Custom permission set for users",
      "type": "object",
      "properties": {
        "name": { 
          "type": "object",
          "properties": {
            "ar": { "type": "string" },
            "en": { "type": "string" }
          },
          "required": ["ar", "en"]
        },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "permissions"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks from the schedule"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Request tracking for metrics"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Generated executive reports"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/customRoles/{roleId}": {
      "schema": "CustomRole",
      "description": "Custom roles and permissions"
    }
  }
}
